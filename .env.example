# ─────────────────────────────────────────────────────────────
# DICSSA Infraestructura — Variables de entorno
# Copie este archivo a .env.local y rellene los valores.
# ─────────────────────────────────────────────────────────────

# URL pública del sitio (sin slash final)
NEXT_PUBLIC_SITE_URL=https://www.grupodicssa.mx

# ── Formularios / Cotización (cuando se conecte el backend) ──
# Endpoint o servicio de correo para recibir cotizaciones y contacto.
QUOTE_NOTIFICATION_EMAIL=contacto@grupodicssa.mx
# SMTP (ej. para nodemailer) o API key de un proveedor (Resend, SendGrid)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=

# ── reCAPTCHA v3 (protección de formularios) ──
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Analytics ──
NEXT_PUBLIC_GA_MEASUREMENT_ID=        # G-XXXXXXXXXX (GA4)
NEXT_PUBLIC_GTM_ID=                   # GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=            # Meta/Facebook Pixel

# ── Supabase (Área de clientes / cotizaciones) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # solo lado servidor, NUNCA exponer

# ── NextAuth (autenticación del portal de clientes) ──
NEXTAUTH_URL=https://www.grupodicssa.mx
NEXTAUTH_SECRET=                      # openssl rand -base64 32

# ── CMS headless (opcional: Sanity) ──
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
